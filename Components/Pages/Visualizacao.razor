@page "/visualizacao"
@rendermode InteractiveServer

<PageTitle>Visualizacao Financeira</PageTitle>

<div class="visualizacao-page">
    <section class="page-title-block">
        <p class="page-kicker">CONSULTA FINANCEIRA</p>
        <h1 class="page-title">Visualizacao de Lancamentos</h1>
        <p class="page-subtitle mb-0">
            Consulte e gerencie os lancamentos cadastrados.
        </p>
    </section>

    <div class="resumo-grid mb-3">
        <article class="resumo-card">
            <p class="resumo-label">A pagar</p>
            <p class="resumo-value text-danger">@TotalPagar.ToString("C")</p>
        </article>
        <article class="resumo-card">
            <p class="resumo-label">A receber</p>
            <p class="resumo-value text-success">@TotalReceber.ToString("C")</p>
        </article>
        <article class="resumo-card">
            <p class="resumo-label">Saldo previsto</p>
            <p class="resumo-value @(SaldoPrevisto >= 0 ? "text-success" : "text-danger")">@SaldoPrevisto.ToString("C")</p>
        </article>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Colunas visiveis</h2>
            <div class="row g-2">
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarTipo" />Tipo</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarDescricao" />Descricao</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarEmpresa" />Empresa</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarCategoria" />Categoria</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarForma" />Metodo de pagamento</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarStatus" />Status</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarValor" />Valor</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarVencimento" />Vencimento</label></div>
                <div class="col-6 col-md-3"><label class="form-check-label d-flex align-items-center gap-2"><InputCheckbox class="form-check-input" @bind-Value="mostrarPagamento" />Pagamento</label></div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Pesquisa</label>
                    <InputText class="form-control" @bind-Value="pesquisa" placeholder="Descricao ou observacao" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Tipo</label>
                    <InputSelect class="form-select" @bind-Value="tipoLancamentoFiltro">
                        <option value="">Todos</option>
                        <option value="Pagar">A pagar</option>
                        <option value="Receber">A receber</option>
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Categoria</label>
                    <InputSelect class="form-select" @bind-Value="categoriaId">
                        <option value="">Todas</option>
                        @foreach (var categoria in categorias)
                        {
                            <option value="@categoria.Id">@categoria.Nome</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Metodo de pagamento</label>
                    <InputSelect class="form-select" @bind-Value="formaPagamentoId">
                        <option value="">Todas</option>
                        @foreach (var forma in formasPagamento)
                        {
                            <option value="@forma.Id">@forma.Nome</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Status</label>
                    <InputSelect class="form-select" @bind-Value="statusId">
                        <option value="">Todos</option>
                        @foreach (var status in statusPendencias)
                        {
                            <option value="@status.Id">@status.Nome</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Empresa</label>
                    <InputText class="form-control" list="empresas-lista" @bind-Value="empresaSelecionada" placeholder="Opcional" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Ordenar por</label>
                    <InputSelect class="form-select" @bind-Value="ordenarPor">
                        <option value="vencimento">Vencimento (padrao)</option>
                        <option value="descricao">Descricao</option>
                        <option value="valor">Valor</option>
                        <option value="status">Status</option>
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Ordem</label>
                    <InputSelect class="form-select" @bind-Value="direcaoOrdenacao">
                        <option value="asc">A-Z</option>
                        <option value="desc">Z-A</option>
                    </InputSelect>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Inicio</label>
                    <InputDate class="form-control" @bind-Value="dataInicio" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Fim</label>
                    <InputDate class="form-control" @bind-Value="dataFim" />
                </div>
                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary" @onclick="BuscarAsync">Aplicar filtros</button>
                    <button class="btn btn-outline-secondary" @onclick="LimparAsync">Limpar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive visualizacao-table-wrap">
        <table class="table table-striped table-hover visualizacao-table">
            <thead>
                <tr>
                    @if (mostrarTipo) { <th class="col-base">Tipo</th> }
                    @if (mostrarDescricao) { <th class="col-descricao">Descricao</th> }
                    @if (mostrarEmpresa) { <th class="col-base">Empresa</th> }
                    @if (mostrarCategoria) { <th class="col-base">Categoria</th> }
                    @if (mostrarForma) { <th class="col-base">Metodo de pagamento</th> }
                    @if (mostrarStatus) { <th class="col-base">Status</th> }
                    @if (mostrarValor) { <th class="col-valor">Valor</th> }
                    @if (mostrarVencimento) { <th class="col-data">Vencimento</th> }
                    @if (mostrarPagamento) { <th class="col-data">Pagamento</th> }
                    <th class="col-acoes">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (movimentacoes.Count == 0)
                {
                    <tr>
                        <td colspan="@ColSpan" class="text-center text-muted">Nenhum registro encontrado com os filtros atuais.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in movimentacoes)
                    {
                        <tr>
                            @if (mostrarTipo)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputSelect class="form-select form-select-sm" @bind-Value="editandoTipoLancamento">
                                            <option value="Pagar">A pagar</option>
                                            <option value="Receber">A receber</option>
                                        </InputSelect>
                                    }
                                    else
                                    {
                                        <span class="tipo-icon @(item.TipoLancamento == "Receber" ? "tipo-receber" : "tipo-pagar")"
                                              title="@(item.TipoLancamento == "Receber" ? "A receber" : "A pagar")"
                                              aria-label="@(item.TipoLancamento == "Receber" ? "A receber" : "A pagar")">
                                            @(item.TipoLancamento == "Receber" ? "↙" : "↗")
                                        </span>
                                    }
                                </td>
                            }
                            @if (mostrarDescricao)
                            {
                                <td class="col-descricao">
                                    @if (editandoId == item.Id)
                                    {
                                        <input class="form-control form-control-sm" @bind="editandoDescricao" />
                                    }
                                    else
                                    {
                                        @item.Descricao
                                    }
                                </td>
                            }
                            @if (mostrarEmpresa)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputText class="form-control form-control-sm" list="empresas-lista" @bind-Value="editandoEmpresaNome" />
                                    }
                                    else
                                    {
                                        @(item.EmpresaFrequente?.Nome ?? "-")
                                    }
                                </td>
                            }
                            @if (mostrarCategoria)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputSelect class="form-select form-select-sm" @bind-Value="editandoCategoriaId">
                                            @foreach (var categoria in categorias)
                                            {
                                                <option value="@categoria.Id">@categoria.Nome</option>
                                            }
                                        </InputSelect>
                                    }
                                    else
                                    {
                                        @item.CategoriaGasto?.Nome
                                    }
                                </td>
                            }
                            @if (mostrarForma)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputSelect class="form-select form-select-sm" @bind-Value="editandoFormaPagamentoId">
                                            @foreach (var forma in formasPagamento)
                                            {
                                                <option value="@forma.Id">@forma.Nome</option>
                                            }
                                        </InputSelect>
                                    }
                                    else
                                    {
                                        @item.FormaPagamento?.Nome
                                    }
                                </td>
                            }
                            @if (mostrarStatus)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputSelect class="form-select form-select-sm" @bind-Value="editandoStatusId">
                                            @foreach (var status in statusPendencias)
                                            {
                                                <option value="@status.Id">@status.Nome</option>
                                            }
                                        </InputSelect>
                                    }
                                    else
                                    {
                                        <span class="status-texto" style="color:@(item.StatusPendencia?.Cor ?? "#334155")">
                                            @item.StatusPendencia?.Nome
                                        </span>
                                    }
                                </td>
                            }
                            @if (mostrarValor)
                            {
                                <td class="col-valor">
                                    @if (editandoId == item.Id)
                                    {
                                        <input type="number" step="0.01" class="form-control form-control-sm" @bind="editandoValor" />
                                    }
                                    else
                                    {
                                        @item.Valor.ToString("C")
                                    }
                                </td>
                            }
                            @if (mostrarVencimento)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputDate class="form-control form-control-sm" @bind-Value="editandoDataVencimento" />
                                    }
                                    else
                                    {
                                        @item.DataVencimento.ToString("dd/MM/yyyy")
                                    }
                                </td>
                            }
                            @if (mostrarPagamento)
                            {
                                <td>
                                    @if (editandoId == item.Id)
                                    {
                                        <InputDate class="form-control form-control-sm" @bind-Value="editandoDataPagamento" />
                                    }
                                    else
                                    {
                                        @(item.DataPagamento?.ToString("dd/MM/yyyy") ?? "-")
                                    }
                                </td>
                            }
                            <td class="col-acoes">
                                <div class="acoes-wrap">
                                    @if (editandoId == item.Id)
                                    {
                                        <CrudButton Text="Salvar" IconClass="fa-solid fa-floppy-disk" Style="CrudButtonStyle.Save" OnClick="@(_ => SalvarAsync())" />
                                        <CrudButton Text="Cancelar" IconClass="fa-solid fa-xmark" Style="CrudButtonStyle.Cancel" OnClick="@(_ => Cancelar())" />
                                    }
                                    else
                                    {
                                        <CrudButton Text="Editar"
                                                    IconClass="fa-solid fa-pen-to-square"
                                                    Style="CrudButtonStyle.Edit"
                                                    OnClick="@(_ => Editar(item))" />
                                        <CrudButton Text="Remover"
                                                    IconClass="fa-solid fa-trash"
                                                    Style="CrudButtonStyle.Remove"
                                                    OnClick="@(_ => RemoverAsync(item.Id))" />
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<datalist id="empresas-lista">
    @foreach (var empresa in empresasFrequentes)
    {
        <option value="@empresa.Nome"></option>
    }
</datalist>
