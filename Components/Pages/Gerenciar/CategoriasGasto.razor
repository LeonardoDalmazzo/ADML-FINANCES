@page "/gerenciar/categorias-gasto"
@rendermode InteractiveServer
@using ADML_FINANCES.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>Categorias de gasto</PageTitle>

<h1>Categorias de gasto</h1>

<div class="mb-3 d-flex gap-2">
    <input class="form-control" placeholder="Nome da categoria" @bind="novoNome" />
    <input class="form-control" placeholder="Descricao da categoria" @bind="novaDescricao" />
    <CrudButton Text="Cadastrar" IconClass="fa-solid fa-plus" Style="CrudButtonStyle.Create" OnClick="CadastrarAsync" />
</div>

<CrudTable TItem="CategoriaGasto"
           Headers="headers"
           Items="itens">
    <RowTemplate Context="item">
        <td>@item.Id</td>
        <td>
            @if (editandoId == item.Id)
            {
                <input class="form-control form-control-sm" @bind="editandoNome" />
            }
            else
            {
                @item.Nome
            }
        </td>
        <td>
            @if (editandoId == item.Id)
            {
                <input class="form-control form-control-sm" @bind="editandoDescricao" />
            }
            else
            {
                @item.Descricao
            }
        </td>
    </RowTemplate>
    <ActionsTemplate Context="item">
        <CrudButton Text="Editar"
                    IconClass="fa-solid fa-pen-to-square"
                    Style="CrudButtonStyle.Edit"
                    OnClick="@(_ => Editar(item))"
                    Disabled="@(editandoId == item.Id)" />
        <CrudButton Text="Remover"
                    IconClass="fa-solid fa-trash"
                    Style="CrudButtonStyle.Remove"
                    OnClick="@(_ => RemoverAsync(item.Id))"
                    Disabled="@(editandoId == item.Id)" />
        @if (editandoId == item.Id)
        {
            <CrudButton Text="Salvar" IconClass="fa-solid fa-floppy-disk" Style="CrudButtonStyle.Save" OnClick="@(_ => SalvarAsync())" />
            <CrudButton Text="Cancelar" IconClass="fa-solid fa-xmark" Style="CrudButtonStyle.Cancel" OnClick="@(_ => Cancelar())" />
        }
    </ActionsTemplate>
</CrudTable>

@code {
    private readonly IReadOnlyList<string> headers = ["Id", "Nome", "Descricao"];
    private List<CategoriaGasto> itens = [];
    private string novoNome = string.Empty;
    private string novaDescricao = string.Empty;
    private Guid? editandoId;
    private string editandoNome = string.Empty;
    private string editandoDescricao = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        itens = await Db.CategoriasGasto
            .OrderBy(x => x.Nome)
            .ToListAsync();
    }

    private async Task CadastrarAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(novoNome) || string.IsNullOrWhiteSpace(novaDescricao))
        {
            return;
        }

        Db.CategoriasGasto.Add(new CategoriaGasto
        {
            Id = Guid.NewGuid(),
            Nome = novoNome.Trim(),
            Descricao = novaDescricao.Trim()
        });

        await Db.SaveChangesAsync();
        novoNome = string.Empty;
        novaDescricao = string.Empty;
        await CarregarAsync();
    }

    private void Editar(CategoriaGasto item)
    {
        editandoId = item.Id;
        editandoNome = item.Nome;
        editandoDescricao = item.Descricao;
    }

    private async Task SalvarAsync()
    {
        if (editandoId is null || string.IsNullOrWhiteSpace(editandoNome) || string.IsNullOrWhiteSpace(editandoDescricao))
        {
            return;
        }

        var item = await Db.CategoriasGasto.FirstOrDefaultAsync(x => x.Id == editandoId.Value);
        if (item is null)
        {
            return;
        }

        item.Nome = editandoNome.Trim();
        item.Descricao = editandoDescricao.Trim();

        await Db.SaveChangesAsync();
        Cancelar();
        await CarregarAsync();
    }

    private async Task RemoverAsync(Guid id)
    {
        var item = await Db.CategoriasGasto.FirstOrDefaultAsync(x => x.Id == id);
        if (item is null)
        {
            return;
        }

        Db.CategoriasGasto.Remove(item);
        await Db.SaveChangesAsync();

        if (editandoId == id)
        {
            Cancelar();
        }

        await CarregarAsync();
    }

    private void Cancelar()
    {
        editandoId = null;
        editandoNome = string.Empty;
        editandoDescricao = string.Empty;
    }
}
